{
  "expo": {
    "name": "ExcelSoft App",
    "slug": "excelsoft-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brandlogo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/brandlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.excelsoft.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brandlogo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.excelsoft.app",
      "versionCode": 1,
      "permissions": [],
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/brandlogo.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aea6cfd3-263e-485d-b179-a859b7197f9e"
      }
    },
    "owner": "sudhaswitha"
  }
}
