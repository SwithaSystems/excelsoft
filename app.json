{
  "expo": {
    "name": "Weekes",
    "slug": "excelsoft-app",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/ClientLogo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/SplashScreenLogo(1).png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.excelsoft.app",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to allow users to take photos for their profile or uploads.",
        "NSPhotoLibraryUsageDescription": "This app uses your photo library to let you select images for uploads or customization.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to provide location-based content or services.",
        "NSFaceIDUsageDescription": "This app uses Face ID for secure authentication."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ClientLogoAndroid.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.excelsoft.app",
      "versionCode": 7,
      "newArchEnabled": true,
      "permissions": ["NOTIFICATION", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/AppLibraryIcon.png"
    },
    "plugins": [
      [
        "expo-media-library",

        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos."
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": "New messages"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aea6cfd3-263e-485d-b179-a859b7197f9e"
      }
    },
    "owner": "sudhaswitha"
  }
}
