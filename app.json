{
  "expo": {
    "name": "Weekes",
    "slug": "excelsoft-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/shortLogo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/SplashScreenLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.excelsoft.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to allow users to take photos for their profile or uploads.",
        "NSPhotoLibraryUsageDescription": "This app uses your photo library to let you select images for uploads or customization.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to provide location-based content or services."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brandlogo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.excelsoft.app",
      "versionCode": 1,
      "newArchEnabled": true,
      "permissions": ["NOTIFICATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/brandlogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": "New messages"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aea6cfd3-263e-485d-b179-a859b7197f9e"
      }
    },
    "owner": "sudhaswitha"
  }
}
