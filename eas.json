{
  "cli": {
    "version": ">= 5.9.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "app-bundle",
        "withoutCredentials": false,
        "autoIncrement": true
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "withoutCredentials": false
      }
    }
  }
}
