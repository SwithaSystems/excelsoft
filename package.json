    "@react-navigation/native": "^7.1.6",
    "@reduxjs/toolkit": "^2.6.0",
    "@sendgrid/mail": "^8.1.4",
    "@stripe/stripe-js": "^8.1.0",
    "@stripe/stripe-react-native": "0.50.3",
