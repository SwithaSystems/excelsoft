          "redux-persist",
          "react-native-modal-selector"
        ]
      }
    }
  },
  "overrides": {
    "modal-react-native-web": {
      "react": "$react",
      "react-dom": "$react-dom",
      "react-native-web": "$react-native-web"
    },
    "@callstack/react-theme-provider": {
      "react": "$react"
    },
    "react-art": {
      "react": "$react"
    }
  },
  "private": true
