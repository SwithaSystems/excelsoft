    "@react-native-community/cli": "^20.0.1",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.20",
    "@types/react": "~19.1.10",
    "@types/react-native-bcrypt": "^2.4.6",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
